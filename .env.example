# ============================================================
# Cricket Management Backend - Environment Variables
# Copy this file to .env and fill in all values
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB ---
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/cricket_db?retryWrites=true&w=majority

# --- JWT Secrets (use strong random strings, min 64 chars each) ---
ACCESS_TOKEN_SECRET=replace_with_strong_random_secret_min_64_chars
REFRESH_TOKEN_SECRET=replace_with_another_strong_random_secret_min_64_chars

# --- JWT Expiry ---
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# --- Admin Email (OTP is sent here) ---
ADMIN_EMAIL=admin@yourdomain.com

# --- Nodemailer (Gmail SMTP example) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
# Use Gmail App Password (not your main password)
SMTP_PASS=your_app_password_here

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- OTP ---
OTP_EXPIRY_MINUTES=10

# --- CORS ---
FRONTEND_URL=http://localhost:3000
